rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── إيصالات الدفع (المسار القديم — إبقاء للتوافق) ────────────────────────────
    // المسار: receipts/{memberId}/{paymentId}/{fileName}
    match /receipts/{memberId}/{paymentId}/{fileName} {

      // القراءة: العضو يقرأ ملفاته فقط، الأدمن يقرأ الكل
      allow read: if request.auth != null &&
        (request.auth.uid == memberId || isAdmin());

      // الرفع: العضو يرفع في مجلده فقط
      // الحجم الأقصى: 10 ميجابايت
      // الأنواع المسموحة: صور + PDF
      allow write: if request.auth != null &&
        request.auth.uid == memberId &&
        request.resource.size <= 10 * 1024 * 1024 &&
        request.resource.contentType in [
          'image/jpeg', 'image/png', 'image/webp', 'application/pdf'
        ];

      // الحذف: الأدمن فقط
      allow delete: if isAdmin();
    }

    // ── صورة الملف الشخصي ────────────────────────────
    // المسار: users/{userId}/profile/{fileName}
    match /users/{userId}/profile/{fileName} {
      // أي مستخدم مسجّل يستطيع القراءة (الصورة تظهر داخل التطبيق).
      allow read: if request.auth != null;

      // الرفع: صاحب الحساب فقط، صور فقط، حد أقصى 5 ميجابايت.
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size <= 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // ── إيصالات الدفع داخل المجلس (المسار المعتمد) ────────────────────────────
    // المسار: organizations/{orgId}/members/{userId}/receipts/{receiptId}/{fileName}
    match /organizations/{organizationId}/members/{userId}/receipts/{receiptId}/{fileName} {

      // القراءة المباشرة: صاحب الإيصال فقط. المراجع المالي يحصل على رابط قصير
      // العمر من getFinancialReceiptDownloadUrl بعد تحقق خادمي من العضوية عبر
      // userId؛ وبذلك لا نفترض أن membershipId يساوي Firebase Auth uid.
      allow read: if request.auth != null &&
        request.auth.uid == userId;

      // الرفع: صاحب الحساب فقط، صور أو PDF، حد أقصى 10 ميجابايت.
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.metadata.temporaryUpload == 'true' &&
        request.resource.metadata.receiptId == receiptId &&
        request.resource.metadata.uploaderUid == userId &&
        request.resource.metadata.organizationId == organizationId &&
        request.resource.metadata.uploadedAt is string &&
        request.resource.size <= 10 * 1024 * 1024 &&
        request.resource.contentType in [
          'image/jpeg', 'image/png', 'image/webp', 'application/pdf'
        ];

      // لا حذف مباشر من العميل (soft-review فقط).
      allow update, delete: if false;
    }

    // ── دوال مساعدة ─────────────────────────────────────────────────────────
    // مهم: في Storage Rules يجب تعريف الدوال **داخل** كتلة match؛ تعريفها على
    // مستوى service (خارج match /b/{bucket}/o) يُفشل تصريف الملف بالكامل فيُرفض
    // النشر وتبقى القواعد المنشورة قديمة (سبب firebase_storage/unauthorized رغم
    // صحّة المسار). firestore.get() على مستند غير موجود يُفشل التقييم، لذا نتحقق
    // دائمًا عبر firestore.exists() أولاً.
    function isAdmin() {
      return isSystemOwner() ||
        (request.auth != null && firestore.exists(
          /databases/(default)/documents/members/$(request.auth.uid)
        ) &&
        firestore.get(
          /databases/(default)/documents/members/$(request.auth.uid)
        ).data.get('isAdmin', false) == true);
    }

    // system_owner منصة منفصل. superAdmin توافق قديم ويتطلب fullAccess.
    function isSystemOwner() {
      return request.auth != null &&
        firestore.exists(
          /databases/(default)/documents/platform_admins/$(request.auth.uid)
        ) &&
        firestore.get(
          /databases/(default)/documents/platform_admins/$(request.auth.uid)
        ).data.get('status', '') == 'active' &&
        (firestore.get(
           /databases/(default)/documents/platform_admins/$(request.auth.uid)
         ).data.get('role', '') == 'system_owner' ||
         (firestore.get(
            /databases/(default)/documents/platform_admins/$(request.auth.uid)
          ).data.get('role', '') == 'superAdmin' &&
          firestore.get(
            /databases/(default)/documents/platform_admins/$(request.auth.uid)
          ).data.get('fullAccess', false) == true));
    }

    function isSuperAdmin() {
      return isSystemOwner();
    }

  }
}
