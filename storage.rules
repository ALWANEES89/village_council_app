rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── إيصالات الدفع ────────────────────────────
    // المسار: receipts/{memberId}/{paymentId}/{fileName}
    match /receipts/{memberId}/{paymentId}/{fileName} {

      // القراءة: العضو يقرأ ملفاته فقط، الأدمن يقرأ الكل
      allow read: if request.auth != null &&
        (request.auth.uid == memberId || isAdmin());

      // الرفع: العضو يرفع في مجلده فقط
      // الحجم الأقصى: 10 ميجابايت
      // الأنواع المسموحة: صور + PDF
      allow write: if request.auth != null &&
        request.auth.uid == memberId &&
        request.resource.size <= 10 * 1024 * 1024 &&
        (request.resource.contentType.matches('image/.*') ||
         request.resource.contentType == 'application/pdf');

      // الحذف: الأدمن فقط
      allow delete: if isAdmin();
    }
  }

  // دالة مساعدة للتحقق من صلاحية الأدمن من Firestore
  function isAdmin() {
    return request.auth != null &&
      firestore.get(
        /databases/(default)/documents/members/$(request.auth.uid)
      ).data.get('isAdmin', false) == true;
  }
}
